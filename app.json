{
  "expo": {
    "name": "RxSure",
    "slug": "rxsure-patient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rxsure",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c1d3d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uk.co.rxsure.patient",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to login quickly and securely",
        "NSCameraUsageDescription": "Take photos for your profile or medical documents"
      }
    },
    "android": {
      "package": "uk.co.rxsure.patient",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c1d3d"
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow RxSure to use Face ID for quick login"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "touqeerhameed"
  }
}
